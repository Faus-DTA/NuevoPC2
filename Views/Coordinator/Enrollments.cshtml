@model IEnumerable<NuevoPC2.Models.Enrollment>

@{
    ViewData["Title"] = "Gestión de Matrículas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Matrículas del curso: <span class="text-primary">@ViewBag.CourseName</span></h2>
        <a asp-action="Index" class="btn btn-secondary">Volver a Cursos</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-center text-muted">
                    <p class="mb-0">Aún no hay estudiantes matriculados en este curso.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Estudiante (Email)</th>
                                <th>Fecha de Registro</th>
                                <th>Estado Actual</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="align-middle">@item.User?.Email</td>
                                    <td class="align-middle">@item.RegistrationDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="align-middle">
                                        @if (item.Status == NuevoPC2.Models.EnrollmentStatus.Pendiente)
                                        {
                                            <span class="badge bg-warning text-dark">Pendiente</span>
                                        }
                                        else if (item.Status == NuevoPC2.Models.EnrollmentStatus.Confirmada)
                                        {
                                            <span class="badge bg-success">Confirmada</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Cancelada</span>
                                        }
                                    </td>
                                    <td class="align-middle text-end">
                                        <form asp-action="UpdateEnrollmentStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            @if (item.Status == NuevoPC2.Models.EnrollmentStatus.Pendiente)
                                            {
                                                <button type="submit" name="status" value="@NuevoPC2.Models.EnrollmentStatus.Confirmada" class="btn btn-sm btn-success me-1">Confirmar</button>
                                                <button type="submit" name="status" value="@NuevoPC2.Models.EnrollmentStatus.Cancelada" class="btn btn-sm btn-danger">Cancelar</button>
                                            }
                                            else if (item.Status == NuevoPC2.Models.EnrollmentStatus.Confirmada)
                                            {
                                                <button type="submit" name="status" value="@NuevoPC2.Models.EnrollmentStatus.Cancelada" class="btn btn-sm btn-danger">Cancelar</button>
                                            }
                                            else if (item.Status == NuevoPC2.Models.EnrollmentStatus.Cancelada)
                                            {
                                                <button type="submit" name="status" value="@NuevoPC2.Models.EnrollmentStatus.Pendiente" class="btn btn-sm btn-warning">Mover a Pendiente</button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

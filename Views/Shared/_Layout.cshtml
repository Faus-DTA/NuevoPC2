<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NuevoPC2</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NuevoPC2.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">NuevoPC2</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Courses" asp-action="Index">Catálogo de Cursos</a>
                        </li>
                        @if (User.IsInRole("Coordinador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-area="" asp-controller="Coordinator" asp-action="Index">Panel Coordinador</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        
        @{
            var lastCourseId = Context.Session.GetInt32("LastCourseId");
            var lastCourseName = Context.Session.GetString("LastCourseName");
            if (lastCourseId.HasValue && !string.IsNullOrEmpty(lastCourseName))
            {
                <div class="alert alert-secondary py-2 mb-3 shadow-sm d-flex justify-content-between align-items-center" role="alert">
                    <span>
                        <i class="bi bi-clock-history me-2"></i> Último curso visitado: <strong>@lastCourseName</strong>
                    </span>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@lastCourseId" class="btn btn-sm btn-outline-primary">
                        Volver al curso
                    </a>
                </div>
            }
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - NuevoPC2 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
